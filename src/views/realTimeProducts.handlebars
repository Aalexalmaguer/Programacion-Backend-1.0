<h1>Productos en Tiempo Real</h1>

<h3>Agregar un producto</h3>
<form id="addProductForm">
    <input type="text" id="title" placeholder="Titulo" required>
    <input type="text" id="description" placeholder="Descripción" required>
    <input type="number" id="price" placeholder="Precio" required>
    <input type="text" id="code" placeholder="Código (ID)" required>
    <input type="number" id="stock" placeholder="Stock" required>
    <input type="text" id="category" placeholder="Categoría" required>
    <button type="submit">Agregar</button>
</form>

<h3>Eliminar un producto</h3>
<form id="deleteProductForm">
    <input type="text" id="deleteId" placeholder="ID del producto a eliminar" required>
    <button type="submit">Eliminar</button>
</form>

<ul id="productList"></ul>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/realtime.js"></script>