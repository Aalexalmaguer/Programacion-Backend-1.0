<h1>Catálogo de Productos</h1>

<ul>
    {{#each products}}
    <li style="margin-bottom: 15px;">
        <strong>{{this.title}}</strong> - ${{this.price}} <br>
        <a href="/products/{{this._id}}">
            <button>Ver Detalles</button>
        </a>
        <button onclick="addToCart('{{this._id}}')">Agregar al Carrito</button>
    </li>
    {{/each}}
</ul>

<div style="margin-top: 20px;">
    {{#if hasPrevPage}}
        <a href="/products?page={{prevPage}}"><button>Anterior</button></a>
    {{/if}}
    
    <span style="margin: 0 15px;">Página {{page}}</span>
    
    {{#if hasNextPage}}
        <a href="/products?page={{nextPage}}"><button>Siguiente</button></a>
    {{/if}}
</div>

<script>
    // NOTA: Para probar este botón, deberás crear un carrito usando Postman o ThunderClient primero
    // y pegar su ID aquí adentro:
    const CART_ID = "PEGA_AQUI_EL_ID_DE_TU_CARRITO"; 

    async function addToCart(productId) {
        if(CART_ID === "PEGA_AQUI_EL_ID_DE_TU_CARRITO") {
            alert("Primero debes poner el ID de un carrito válido en el código HTML.");
            return;
        }

        try {
            const response = await fetch(`/api/carts/${CART_ID}/product/${productId}`, {
                method: 'POST'
            });
            if(response.ok) {
                alert("¡Producto agregado al carrito exitosamente!");
            } else {
                alert("Hubo un error al agregar el producto");
            }
        } catch (error) {
            console.error(error);
        }
    }
</script>