<h1>Detalles del Producto</h1>

<div style="border: 1px solid #ccc; padding: 20px; max-width: 400px;">
    <h2>{{product.title}}</h2>
    <p><strong>Descripción:</strong> {{product.description}}</p>
    <p><strong>Categoría:</strong> {{product.category}}</p>
    <p><strong>Precio:</strong> ${{product.price}}</p>
    <p><strong>Stock disponible:</strong> {{product.stock}} unidades</p>
    <p><strong>Código:</strong> {{product.code}}</p>
    
    <button style="margin-top: 15px; padding: 10px; background-color: #28a745; color: white; border: none; cursor: pointer;">
        Agregar al Carrito
    </button>
    <br><br>
    <a href="/products">Volver al catálogo</a>
</div>